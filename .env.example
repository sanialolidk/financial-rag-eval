# Required for answer generation and LLM-as-judge evaluation
OPENAI_API_KEY=sk-...

# Model selection (defaults shown)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini

# SEC EDGAR requires a descriptive User-Agent (name + email)
SEC_USER_AGENT=FinRAGEval your.email@example.com

# API / UI
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Retrieval tuning
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
HYBRID_TOP_K=20
RERANK_TOP_K=5
DENSE_WEIGHT=0.5
BM25_WEIGHT=0.5

# Eval alert thresholds
FAITHFULNESS_ALERT_THRESHOLD=0.7
CHUNK_RECALL_ALERT_THRESHOLD=0.5

# Cost (USD per 1M tokens — update for your model)
INPUT_COST_PER_1M=0.15
OUTPUT_COST_PER_1M=0.60